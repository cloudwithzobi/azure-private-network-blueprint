# Terraform state files (contain secrets)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform working directory (huge, auto-generated)
.terraform/
.terraform.lock.hcl

# Variable values (often contain environment-specific secrets)
*.tfvars
!example.tfvars

# Plan files (can contain sensitive data)
tfplan
*.tfplan

# SSH keys — never commit these
*.pem
*.key
id_rsa*

# OS / Editor clutter
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
